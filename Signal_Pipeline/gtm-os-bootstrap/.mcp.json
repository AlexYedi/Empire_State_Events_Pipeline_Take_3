{
  "mcpServers": {
    "notion": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.notion.com/mcp"]
    },
    "hubspot": {
      "command": "npx",
      "args": ["-y", "@hubspot/mcp-server"],
      "env": {
        "PRIVATE_APP_ACCESS_TOKEN": "${HUBSPOT_PRIVATE_APP_TOKEN}"
      }
    },
    "linear": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.linear.app/mcp"]
    },
    "posthog": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.posthog.com/mcp",
        "--header",
        "Authorization:Bearer ${POSTHOG_API_KEY}"
      ]
    },
    "clay": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://api.clay.com/v3/mcp",
        "--header",
        "Authorization:Bearer ${CLAY_API_KEY}"
      ]
    },
    "granola": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.granola.ai/mcp"]
    },
    "google-calendar": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://gcal.mcp.claude.com/mcp"]
    },
    "gmail": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://gmail.mcp.claude.com/mcp"]
    },
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--access-token",
        "${SUPABASE_ACCESS_TOKEN}"
      ]
    },
    "vercel": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.vercel.com"]
    },
    "n8n": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://yedimaing.app.n8n.cloud/mcp-server/http",
        "--header",
        "Authorization:Bearer ${N8N_API_KEY}"
      ]
    }
  }
}
