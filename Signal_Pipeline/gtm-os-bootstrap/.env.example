# gtm-os environment variables
#
# Copy this to `.env` (NEVER commit .env). Each server in .mcp.json that needs
# a token references one of these vars. Servers using OAuth handle auth on
# first run via /mcp in the Claude Code session — no token needed here.
#
# Order of servers below matches Tier 1 in MCP_SETUP.md.
# ─────────────────────────────────────────────────────────────────────────────

# ── 1. Notion ───────────────────────────────────────────────────────────────
# Auth: OAuth via hosted MCP. No token here. Run /mcp on first session.

# ── 2. HubSpot ──────────────────────────────────────────────────────────────
# Auth: Private App access token.
# Create at: HubSpot → Settings → Integrations → Private Apps → Create.
# Required scopes (mirror existing Claude.ai connector):
#   crm.objects.contacts.read, crm.objects.contacts.write
#   crm.objects.companies.read, crm.objects.companies.write
#   crm.objects.deals.read, crm.objects.deals.write
#   crm.objects.owners.read           (HubSpot owner ID 90413044)
#   sales-email-read                  (engagements/notes access)
HUBSPOT_PRIVATE_APP_TOKEN=

# ── 3. Linear ───────────────────────────────────────────────────────────────
# Auth: OAuth via hosted MCP. No token here. Run /mcp on first session.

# ── 4. PostHog ──────────────────────────────────────────────────────────────
# Auth: Personal API key.
# Create at: PostHog → Settings → Personal API keys → Create personal API key.
# Recommended scopes: read on insights, dashboards, feature_flags, query.
# Add write scopes if/when you want Claude to create dashboards from sessions.
POSTHOG_API_KEY=

# ── 5. Clay ─────────────────────────────────────────────────────────────────
# Auth: API key.
# Create at: Clay → Settings → API → Generate API key.
# Plan check: confirm your Clay plan exposes the v3 MCP endpoint.
CLAY_API_KEY=

# ── 6. Granola ──────────────────────────────────────────────────────────────
# Auth: OAuth via hosted MCP. No token here. Run /mcp on first session.

# ── 7. Google Calendar ──────────────────────────────────────────────────────
# Auth: OAuth via hosted MCP at gcal.mcp.claude.com.
# FLAG: this URL is Anthropic's hosted Workspace connector — confirmed for
# Claude.ai chat, ~65% confidence it works in Claude Code CLI. If /mcp fails
# OAuth here, see MCP_FALLBACKS.md for the npm-package fallback (requires
# your own GCP OAuth client credentials).

# ── 8. Gmail ────────────────────────────────────────────────────────────────
# Auth: same as Google Calendar (hosted at gmail.mcp.claude.com).
# Same fallback applies if hosted URL doesn't authenticate from CLI.

# ── 9. Supabase ─────────────────────────────────────────────────────────────
# Auth: Personal Access Token (NOT a project anon/service key).
# Create at: Supabase → Account → Access Tokens → Generate new token.
# Scope is account-wide — limits to projects you have access to.
SUPABASE_ACCESS_TOKEN=

# ── 10. Vercel ──────────────────────────────────────────────────────────────
# Auth: OAuth via hosted MCP. No token here. Run /mcp on first session.

# ── 11. n8n ─────────────────────────────────────────────────────────────────
# Auth: API key from your self-hosted n8n cloud instance.
# Create at: n8n → Settings → n8n API → Create API key.
# Instance: yedimaing.app.n8n.cloud
N8N_API_KEY=
