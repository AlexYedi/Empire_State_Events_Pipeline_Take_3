# HubSpot Private App access token.
# Create at: HubSpot account → Settings → Integrations → Private Apps → Create private app.
# Required scopes (mirror your existing Claude.ai connector permissions):
#   crm.objects.contacts.read, crm.objects.contacts.write
#   crm.objects.companies.read, crm.objects.companies.write
#   crm.objects.deals.read, crm.objects.deals.write
#   crm.objects.notes.read (NOTE: HubSpot calls these "engagements")
#   crm.objects.owners.read
# After creating, copy the Access Token from the Auth tab and paste below.
HUBSPOT_PRIVATE_APP_TOKEN=

# Notion uses the hosted MCP at https://mcp.notion.com/mcp via OAuth — no token needed here.
# Authenticate by running /mcp in Claude Code after the .mcp.json is in place.
